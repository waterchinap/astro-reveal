const cdata = {cpu:1000, gpu:2000, ddr5:1000, ssd:1500}
const pagedata = {
        "indexCode": "399812.SZ",
        "indexName": "养老产业",
        "date": 1782230400000,
        "pe": 10.63,
        "pePercentile": 0.0014,
