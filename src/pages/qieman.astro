---
import RevealLayout from '../layouts/RevealLayout.astro'
import Cover from '../components/Cover.astro'
import CardTableSlide from '../components/CardTableSlide.astro'
import TitleH2 from '../components/TitleH2.astro'
import qieman from '../assets/qieman.json'
import emnews from '../assets/emnews.json'

const data = qieman.idxEvalList
const emtitle = emnews['标题']

function toPercent(value, decimals = 2) {
  if (typeof value !== 'number' || isNaN(value)) {
    return '';
  }
  return (value * 100).toFixed(decimals) + '%';
}
const sel = data.map(
  ({indexCode, indexName, pe, pePercentile, pb, pbPercentile, roe, group}) => ({
    指数名称: indexName,
    指数代码: indexCode,
    pe,
    pe百分位: toPercent(pePercentile),
    pb,
    pb百分位: toPercent(pbPercentile),
    roe: toPercent(roe),
    group
  })
)
const pdate = new Date(qieman.date).toLocaleDateString('zh-CN')
---

<RevealLayout>

<Cover title='指数估值精选' subtitle={pdate} />
<CardTableSlide carddata={sel} cols=2 rows=1 />

<Cover title='东方财富新闻' subtitle={pdate} />
{Object.values(emtitle).slice(0,100).map(item => <TitleH2 title={item} />)}

</RevealLayout>

