---
import Card from '../components/Card.astro'

const {title, carddata, cols=3 } = Astro.props;

const colClasses = {
  1: 'grid-cols-1',
  2: 'grid-cols-2',
  3: 'grid-cols-3',
  4: 'grid-cols-4',
  5: 'grid-cols-5',
  6: 'grid-cols-6',
};
const gridClass = colClasses[cols] || 'grid-cols-3';

const cardEntries = Object.entries(carddata);
---
<section>
  {title && <h1>{title}</h1>}
  <div class={`grid ${gridClass} gap-4`}>
    {cardEntries.map(([key, value]) => (
      <Card 
        cardtitle={key} 
        cardvalue={value} 
      />
    ))}
  </div>
</section>
