---
const { cols=3 } = Astro.props;

const colClasses = {
  1: 'grid-cols-1',
  2: 'grid-cols-2',
  3: 'grid-cols-3',
  4: 'grid-cols-4',
  5: 'grid-cols-5',
  6: 'grid-cols-6',
};
const gridClass = colClasses[cols] || 'grid-cols-3';
---

<div class={`grid ${gridClass} gap-4 justify-center justify-items-center`}>
  <slot />
</div>
